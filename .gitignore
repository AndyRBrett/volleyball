__pycache__/
*.pyc

# Ingested footage is large/private -- keep it out of git (the folder is kept
# via drop/.gitkeep). Ingest state/queue JSON ARE committed so "seen" state
# persists across fresh CI checkouts.
drop/*
!drop/.gitkeep

# Local-run pipeline artifacts at the REPO ROOT are regenerated and need not be
# committed. These are anchored with a leading "/" so they only match the root
# copies -- the per-clip outputs the process-footage workflow publishes under
# reports/<clip>/ (coaching summary, manifest, rendered clips) ARE committed so
# the PWA can read them.
/highlights/*.mp4
/coaching/
/results/metrics.json
!/results/selftest.json
