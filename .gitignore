__pycache__/
*.pyc

# Ingested footage is large/private -- keep it out of git (the folder is kept
# via drop/.gitkeep). Ingest state/queue JSON ARE committed so "seen" state
# persists across fresh CI checkouts.
drop/*
!drop/.gitkeep

# Rendered highlight clips are large; the manifest (highlights/manifest.json)
# is the dashboard artifact and may be committed if desired.
highlights/*.mp4

# Per-run pipeline artifacts are regenerated from footage and need not be
# committed. results/selftest.json IS committed (it's the pipeline-verified
# heartbeat the overseer reads), so it's explicitly un-ignored.
coaching/
results/metrics.json
!results/selftest.json
